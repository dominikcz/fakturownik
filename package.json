		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.2",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@ksefuj/validator": "^0.3.0",
		"@zerodevx/svelte-toast": "^0.9.6",
		"ksef-client": "^0.5.2",
		"node-forge": "^1.4.0",
		"qrcode": "^1.5.4",
		"uuid": "^13.0.0"
	}
