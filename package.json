		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"@types/node-forge": "^1.3.14",
		"@types/qrcode": "^1.5.6",
		"@types/uuid": "^10.0.0",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
