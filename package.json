		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22.19.17",
		"@types/node-forge": "^1.3.14",
		"@types/qrcode": "^1.5.6",
		"@types/uuid": "^10.0.0",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"playwright": "^1.58.2",
